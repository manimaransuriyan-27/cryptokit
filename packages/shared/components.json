{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-vega",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "css": "src/styles/globals.css",
    "baseColor": "neutral",
    "cssVariables": true
  },
  "iconLibrary": "lucide",
  "rtl": true,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@repo/shared/components",
    "utils": "@repo/shared/lib/utils",
    "lib": "@repo/shared/lib",
    "hooks": "@repo/shared/hooks"
  },
  "registries": {
    "@magicui": "https://magicui.design/r/{name}",
    "@shadcnuikit": "https://shadcnuikit.com/r/{name}.json"
  }
}
