{
  "name": "cryptokit",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "web:dev": "pnpm run --filter=web dev",
    "prisma:stdo": "pnpm run --filter=server prisma:studio",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "clean-modules": "sh ./clean.sh",
    "reinstall": "pnpm clean && pnpm clean-modules && pnpm install && pnpm store prune && pnpm cache prune"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  }
}
